# === データベース ===
DATABASE_URL=           # NeonのPostgreSQL接続URL

# === 検索順位取得 ===
SERPAPI_KEY=            # SerpAPI APIキー（https://serpapi.com/ で取得）

# === AIリライト ===
ANTHROPIC_API_KEY=      # Claude APIキー（https://console.anthropic.com/ で取得）

# === WordPress ===
WP_SITE_URL=            # WordPressサイトURL（例: https://example.com）
WP_USERNAME=            # WordPressユーザー名
WP_APP_PASSWORD=        # WordPressアプリケーションパスワード

# === X (Twitter) ===
X_API_KEY=              # X API Key
X_API_SECRET=           # X API Secret
X_ACCESS_TOKEN=         # X Access Token
X_ACCESS_SECRET=        # X Access Secret

# === Facebook / Instagram ===
FACEBOOK_PAGE_ID=       # FacebookページID
FACEBOOK_ACCESS_TOKEN=  # Facebookアクセストークン（Instagram共用）
INSTAGRAM_BUSINESS_ACCOUNT_ID=  # Instagramビジネスアカウント ID

# === セキュリティ ===
CRON_SECRET=            # Cron不正アクセス防止トークン
